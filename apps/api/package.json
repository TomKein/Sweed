{
  "name": "@sweed/api",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "bun src/db/migrate.ts up",
    "db:rollback": "bun src/db/migrate.ts down",
    "db:codegen": "kysely-codegen --out-file src/db/db-types.ts"
  },
  "dependencies": {
    "@sweed/shared": "workspace:*",
    "elysia": "^1.4.29",
    "jose": "^6.2.3",
    "kysely": "^0.29.2",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "kysely-codegen": "^0.20.0"
  }
}

