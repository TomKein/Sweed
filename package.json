{
  "name": "sweed",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --hot apps/api/src/main.ts",
    "dev:web": "bun run --cwd apps/web dev",
    "typecheck": "bun run scripts/typecheck.ts",
    "test": "bun test",
    "db:migrate": "bun run --cwd apps/api db:migrate",
    "db:rollback": "bun run --cwd apps/api db:rollback",
    "db:codegen": "bun run --cwd apps/api db:codegen"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
